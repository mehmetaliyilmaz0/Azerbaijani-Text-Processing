# =============================================================================
# CENG442 — Azerbaijani Sentiment Analysis
# .gitignore — Principal Engineer Edition
# =============================================================================

# ---------------------------------------------------------
# 1) SECRETS & CREDENTIALS
# ---------------------------------------------------------
# YouTube Data API key must NEVER be committed.
# Store in environment: export YOUTUBE_API_KEY="..."
.env
.env.*
*.env
secrets.py
api_key*.txt

# ---------------------------------------------------------
# 2) ASSIGNMENT & COURSE DOCUMENTS (personal / institutional)
# ---------------------------------------------------------
# Assignment spec, submission logs, grading docs
CENG442*

# Old plain-text readme
README.txt

# ---------------------------------------------------------
# 3) LARGE BINARY MODEL FILES (would destroy repo size)
# ---------------------------------------------------------
# Trained Keras model: ~1.28 GB
best_sentiment_model.keras
*.keras
*.h5

# Gensim embedding models: Word2Vec + FastText combined ~2.8 GB
embeddings/
!embeddings/.gitkeep

# ---------------------------------------------------------
# 4) RAW SOURCE DATASETS (large binary Excel files)
# ---------------------------------------------------------
# These are the original labeled datasets use for Part 1.
# Re-download from their original sources if needed.
labeled-sentiment.xlsx
test__1_.xlsx
train__3_.xlsx
train-00000-of-00001.xlsx
merged_dataset_CSV__1_.xlsx
*.xlsx

# ---------------------------------------------------------
# 5) LARGE GENERATED DATA / ML ARTIFACTS (reproducible)
# ---------------------------------------------------------
# Full cleaned corpus for embedding training: ~15 MB
corpus_all.txt

# Cleaned Excel outputs (generated by process_assignment.py)
cleaned_data/
!cleaned_data/.gitkeep

# Labeled data with domain assignments (generated by assign_domains.py)
part1_with_domains/
!part1_with_domains/.gitkeep

# YouTube ML predictions output
youtube_predictions.xlsx

# Experiment text reports (regenerated on each run)
final_experiment_report.txt
model_metrics.txt

# ---------------------------------------------------------
# 4) COLLECTED YOUTUBE DATA (Privacy / ToS compliance)
# ---------------------------------------------------------
# YouTube comments contain personal user data.
# Per YouTube ToS §IV.J, redistribution is restricted.
# Re-collect using: python part2_code/collect_youtube_data.py
part2_data/
!part2_data/.gitkeep

# Video metadata (contains viewCount, channelTitle, user data)
video_metadata_all.xlsx

# ---------------------------------------------------------
# 5) OPTUNA HYPERPARAMETER TUNING ARTIFACTS
# ---------------------------------------------------------
optuna_tuning.db
optuna_*.db
*.optuna

# ---------------------------------------------------------
# 6) PYTHON RUNTIME ARTIFACTS
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
.conda/

# ---------------------------------------------------------
# 7) AI ASSISTANT INTERNAL CONFIG
# ---------------------------------------------------------
# CLAUDE.md is an AI system prompt for pair programming.
# Not relevant to the project itself.
CLAUDE.md

